{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Ixe1/codex-plugins/master/plugins/maquette/shared/page-asset-manifest.schema.json",
  "title": "Maquette Page Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "page",
    "status",
    "assets",
    "review"
  ],
  "properties": {
    "page": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "reviewed",
        "approved"
      ]
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "status",
          "required_by"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "logo",
              "hero-image",
              "product-card-image",
              "promo-image",
              "lifestyle-story-image",
              "footer-image",
              "app-device-image",
              "background-texture",
              "decorative-raster",
              "concept-screenshot",
              "page-screenshot",
              "other"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "generated",
              "provided",
              "reused-existing",
              "not-generated-with-reason",
              "missing"
            ]
          },
          "required_by": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "image_gen",
              "user-provided",
              "existing-project",
              "code-generated",
              "not-applicable"
            ]
          },
          "alt_text": {
            "type": "string"
          },
          "generated_visual_fit": {
            "$ref": "#/$defs/generatedVisualFit"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_referenced_assets_exist",
        "missing_assets"
      ],
      "properties": {
        "all_referenced_assets_exist": {
          "type": "boolean"
        },
        "missing_assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "generatedVisualFit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intended_purpose",
        "consumed_by_region",
        "supports_product_function",
        "could_be_mistaken_for_real_feature",
        "distracts_from_primary_task",
        "css_svg_or_code_native_more_appropriate",
        "decision",
        "alt_text_or_decorative_hidden"
      ],
      "properties": {
        "intended_purpose": {
          "type": "string"
        },
        "consumed_by_region": {
          "type": "string"
        },
        "supports_product_function": {
          "type": "boolean"
        },
        "could_be_mistaken_for_real_feature": {
          "type": "boolean"
        },
        "distracts_from_primary_task": {
          "type": "boolean"
        },
        "css_svg_or_code_native_more_appropriate": {
          "type": "boolean"
        },
        "decision": {
          "type": "string",
          "enum": [
            "use",
            "revise",
            "replace",
            "remove"
          ]
        },
        "alt_text_or_decorative_hidden": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
