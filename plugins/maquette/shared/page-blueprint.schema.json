{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Ixe1/codex-plugins/master/plugins/maquette/shared/page-blueprint.schema.json",
  "title": "Maquette Page Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "references",
    "viewports",
    "sections",
    "acceptance_criteria",
    "assets"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_name",
        "page_type",
        "version",
        "status",
        "based_on_component_catalog_version"
      ],
      "properties": {
        "page_name": {
          "type": "string"
        },
        "page_type": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "reviewed",
            "approved"
          ]
        },
        "based_on_component_catalog_version": {
          "type": "string"
        },
        "existing_site_mode": {
          "type": "boolean"
        },
        "reference_page_path": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "brand-board",
              "component-sheet",
              "component-closeup",
              "component-coverage-plan",
              "component-extraction-plan",
              "site-contract",
              "existing-reference-page",
              "page-layout-contract",
              "experience-quality-contract",
              "page-concept-segment",
              "segment-layout-contract",
              "page-concept",
              "other"
            ]
          },
          "path": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "width",
          "height"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "width": {
            "type": "integer",
            "minimum": 320
          },
          "height": {
            "type": "integer",
            "minimum": 320
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "purpose",
          "order",
          "layout",
          "uses_components"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "content_width",
              "columns",
              "alignment"
            ],
            "properties": {
              "content_width": {
                "type": "string"
              },
              "columns": {
                "type": "integer",
                "minimum": 1
              },
              "alignment": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "uses_components": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "variant": {
                  "type": "string"
                },
                "notes": {
                  "type": "string"
                }
              }
            },
            "minItems": 1
          },
          "introduces_new_composite": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "new_composites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "quality_review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "font_rationale": {
          "type": "string"
        },
        "concept_region_inventory": {
          "type": "string"
        },
        "page_layout_contract": {
          "type": "string"
        },
        "experience_quality_contract": {
          "type": "string"
        },
        "asset_manifest": {
          "type": "string"
        },
        "site_contract": {
          "type": "string"
        },
        "site_shell_consistency": {
          "type": "string"
        },
        "component_sheet_gallery_fidelity": {
          "type": "string"
        },
        "component_reuse": {
          "type": "string"
        },
        "component_coverage_plan": {
          "type": "string"
        },
        "component_extraction_plan": {
          "type": "string"
        },
        "component_closeup_focus": {
          "type": "string"
        },
        "component_closeup_screenshot_match": {
          "type": "string"
        },
        "desktop_segment_concepts": {
          "type": "string"
        },
        "segment_layout_contracts": {
          "type": "string"
        },
        "typography_text_fit": {
          "type": "string"
        },
        "font_loading": {
          "type": "string"
        },
        "visual_component_sheet_focus": {
          "type": "string"
        },
        "optional_visual_component_sheet_focus": {
          "type": "string"
        },
        "css_contract_poster_focus": {
          "type": "string"
        },
        "generated_visual_fit": {
          "type": "string"
        },
        "motion_effects": {
          "type": "string"
        },
        "reduced_motion": {
          "type": "string"
        },
        "interaction_state_coverage": {
          "type": "string"
        },
        "accessibility_baseline": {
          "type": "string"
        },
        "performance_review": {
          "type": "string"
        },
        "content_information_architecture": {
          "type": "string"
        },
        "brand_craft": {
          "type": "string"
        },
        "mobile_responsive_ux": {
          "type": "string"
        },
        "context_fit": {
          "type": "string"
        },
        "repeated_card_alignment": {
          "type": "string"
        },
        "footer_fidelity": {
          "type": "string"
        },
        "mobile_drawer_scrollability": {
          "type": "string"
        },
        "social_icon_strategy": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "html_path",
        "concept_region_inventory_path",
        "page_layout_contract_path",
        "asset_manifest_path",
        "screenshot_paths"
      ],
      "properties": {
        "concept_path": {
          "type": "string"
        },
        "concept_segment_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "segment_layout_contract_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "fonts_css_path": {
          "type": "string"
        },
        "html_path": {
          "type": "string"
        },
        "css_path": {
          "type": "string"
        },
        "js_path": {
          "type": "string"
        },
        "screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "segmented_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "desktop_concept_ratio_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "text_fit_report_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nav_open_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "concept_region_inventory_path": {
          "type": "string"
        },
        "component_extraction_plan_path": {
          "type": "string"
        },
        "page_layout_contract_path": {
          "type": "string"
        },
        "experience_quality_contract_path": {
          "type": "string"
        },
        "asset_manifest_path": {
          "type": "string"
        },
        "site_contract_path": {
          "type": "string"
        },
        "shell_consistency_report_path": {
          "type": "string"
        },
        "reference_shell_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_shell_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_notes_path": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "meta": {
            "properties": {
              "existing_site_mode": {
                "const": true
              }
            },
            "required": [
              "existing_site_mode"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "assets": {
            "required": [
              "site_contract_path"
            ]
          }
        }
      }
    }
  ]
}
