{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Ixe1/codex-plugins/master/plugins/maquette/shared/component-catalog.schema.json",
  "title": "Maquette Component Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "tech",
    "assets",
    "components"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_name",
        "version",
        "based_on_design_system_version",
        "status"
      ],
      "properties": {
        "system_name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "based_on_design_system_version": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "approved",
            "superseded"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "tech": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "html_strategy",
        "css_strategy",
        "js_strategy"
      ],
      "properties": {
        "html_strategy": {
          "type": "string"
        },
        "css_strategy": {
          "type": "string"
        },
        "js_strategy": {
          "type": "string"
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens_css_path",
        "gallery_html_path",
        "gallery_screenshot_paths",
        "sheet_fidelity_review"
      ],
      "properties": {
        "tokens_css_path": {
          "type": "string"
        },
        "gallery_html_path": {
          "type": "string"
        },
        "gallery_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "component_sheet_path": {
          "type": "string"
        },
        "component_sheet_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "nav_open_screenshot_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sheet_fidelity_review": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reference_sheet_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "coverage_summary": {
              "type": "string"
            },
            "simplifications": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "status": {
              "type": "string",
              "enum": [
                "matches",
                "deviates",
                "simplified",
                "needs-fix"
              ]
            }
          }
        },
        "review_notes_path": {
          "type": "string"
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "source_required_component",
          "files",
          "selectors",
          "implemented_variants",
          "implemented_sizes",
          "implemented_states",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "source_required_component": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "selectors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "implemented_variants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "implemented_sizes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "implemented_states": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "accessibility_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "layout_behavior": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "equal_height_grid": {
                "type": "string"
              },
              "body_layout": {
                "type": "string"
              },
              "action_row_alignment": {
                "type": "string"
              },
              "responsive_notes": {
                "type": "string"
              }
            }
          },
          "visual_review": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "reference_image_paths": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "latest_screenshot_path": {
                "type": "string"
              },
              "similarity_notes": {
                "type": "string"
              },
              "qa_notes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "reviewed",
              "approved"
            ]
          }
        }
      }
    }
  }
}
