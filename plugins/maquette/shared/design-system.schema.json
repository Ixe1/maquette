{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Ixe1/codex-plugins/master/plugins/maquette/shared/design-system.schema.json",
  "title": "Maquette Design System",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "brief",
    "tokens",
    "components_required",
    "board"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_name",
        "platform",
        "version",
        "status"
      ],
      "properties": {
        "system_name": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "const": "web"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "approved",
            "superseded"
          ]
        },
        "source_mode": {
          "type": "string",
          "enum": [
            "greenfield",
            "existing-site-refresh",
            "reference-derived"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_summary",
        "audience",
        "tone",
        "accessibility"
      ],
      "properties": {
        "product_summary": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "tone": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accessibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "contrast_target",
            "reduced_motion_support",
            "focus_visibility",
            "min_hit_target_px"
          ],
          "properties": {
            "contrast_target": {
              "type": "string",
              "enum": [
                "AA",
                "AAA"
              ]
            },
            "reduced_motion_support": {
              "type": "boolean"
            },
            "focus_visibility": {
              "type": "string",
              "enum": [
                "standard",
                "high-contrast",
                "always-visible"
              ]
            },
            "min_hit_target_px": {
              "type": "integer",
              "minimum": 24
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "role"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "screenshot",
              "brand-board",
              "component-sheet",
              "component-closeup",
              "page-concept",
              "inspiration",
              "other"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "historical",
              "avoid"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "color",
        "typography",
        "space",
        "radius",
        "border",
        "shadow",
        "motion",
        "layout",
        "opacity"
      ],
      "properties": {
        "color": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "palette",
            "semantic"
          ],
          "properties": {
            "palette": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "brand",
                "neutral"
              ],
              "properties": {
                "brand": {
                  "$ref": "#/$defs/paletteFamily"
                },
                "neutral": {
                  "$ref": "#/$defs/paletteFamily"
                },
                "accent": {
                  "$ref": "#/$defs/paletteFamily"
                },
                "success": {
                  "$ref": "#/$defs/paletteFamily"
                },
                "warning": {
                  "$ref": "#/$defs/paletteFamily"
                },
                "danger": {
                  "$ref": "#/$defs/paletteFamily"
                },
                "info": {
                  "$ref": "#/$defs/paletteFamily"
                }
              }
            },
            "semantic": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "background",
                "text",
                "border",
                "action",
                "feedback",
                "state_overlay",
                "focus_ring"
              ],
              "properties": {
                "background": {
                  "$ref": "#/$defs/stringMapMin4"
                },
                "text": {
                  "$ref": "#/$defs/stringMapMin4"
                },
                "border": {
                  "$ref": "#/$defs/stringMapMin3"
                },
                "action": {
                  "$ref": "#/$defs/stringMapMin4"
                },
                "feedback": {
                  "$ref": "#/$defs/stringMapMin4"
                },
                "state_overlay": {
                  "$ref": "#/$defs/stringMapMin4"
                },
                "focus_ring": {
                  "$ref": "#/$defs/stringMapMin1"
                }
              }
            }
          }
        },
        "typography": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "families",
            "weights",
            "scale",
            "usage"
          ],
          "properties": {
            "families": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "body",
                "heading",
                "mono"
              ],
              "properties": {
                "body": {
                  "type": "string"
                },
                "heading": {
                  "type": "string"
                },
                "mono": {
                  "type": "string"
                }
              }
            },
            "weights": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "regular",
                "medium",
                "semibold",
                "bold"
              ],
              "properties": {
                "regular": {
                  "type": "integer",
                  "enum": [
                    300,
                    400,
                    500,
                    600,
                    700,
                    800
                  ]
                },
                "medium": {
                  "type": "integer",
                  "enum": [
                    300,
                    400,
                    500,
                    600,
                    700,
                    800
                  ]
                },
                "semibold": {
                  "type": "integer",
                  "enum": [
                    300,
                    400,
                    500,
                    600,
                    700,
                    800
                  ]
                },
                "bold": {
                  "type": "integer",
                  "enum": [
                    300,
                    400,
                    500,
                    600,
                    700,
                    800
                  ]
                }
              }
            },
            "scale": {
              "type": "object",
              "minProperties": 4,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "font_size",
                  "line_height",
                  "letter_spacing"
                ],
                "properties": {
                  "font_size": {
                    "type": "string"
                  },
                  "line_height": {
                    "type": [
                      "string",
                      "number"
                    ]
                  },
                  "letter_spacing": {
                    "type": "string"
                  },
                  "font_weight": {
                    "type": "integer",
                    "enum": [
                      300,
                      400,
                      500,
                      600,
                      700,
                      800
                    ]
                  }
                }
              }
            },
            "usage": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "body",
                "label",
                "code",
                "h1",
                "h2",
                "h3",
                "h4"
              ],
              "properties": {
                "body": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "h1": {
                  "type": "string"
                },
                "h2": {
                  "type": "string"
                },
                "h3": {
                  "type": "string"
                },
                "h4": {
                  "type": "string"
                },
                "h5": {
                  "type": "string"
                },
                "h6": {
                  "type": "string"
                }
              }
            },
            "font_strategy": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "heading_personality",
                "body_personality",
                "preferred_heading_fonts",
                "preferred_body_fonts",
                "css_fallback_stacks",
                "fallback_rationale"
              ],
              "properties": {
                "heading_personality": {
                  "type": "string"
                },
                "body_personality": {
                  "type": "string"
                },
                "preferred_heading_fonts": {
                  "type": "string"
                },
                "preferred_body_fonts": {
                  "type": "string"
                },
                "css_fallback_stacks": {
                  "type": "string"
                },
                "fallback_rationale": {
                  "type": "string"
                },
                "avoid_fonts": {
                  "type": "string"
                }
              }
            }
          }
        },
        "space": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "base",
            "scale"
          ],
          "properties": {
            "base": {
              "type": "string"
            },
            "scale": {
              "type": "object",
              "minProperties": 8,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "radius": {
          "type": "object",
          "minProperties": 5,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "border": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "width",
            "style",
            "focus_ring"
          ],
          "properties": {
            "width": {
              "type": "object",
              "minProperties": 2,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "style": {
              "type": "string"
            },
            "focus_ring": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "width",
                "offset"
              ],
              "properties": {
                "width": {
                  "type": "string"
                },
                "offset": {
                  "type": "string"
                },
                "radius_strategy": {
                  "type": "string"
                }
              }
            }
          }
        },
        "shadow": {
          "type": "object",
          "minProperties": 3,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "motion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "duration",
            "easing",
            "reduced_motion"
          ],
          "properties": {
            "duration": {
              "type": "object",
              "minProperties": 2,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "easing": {
              "type": "object",
              "minProperties": 2,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "reduced_motion": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enabled",
                "strategy"
              ],
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "strategy": {
                  "type": "string"
                }
              }
            }
          }
        },
        "layout": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "content_width",
            "grid",
            "breakpoints"
          ],
          "properties": {
            "content_width": {
              "type": "object",
              "minProperties": 3,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "grid": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "columns",
                "gutter",
                "margin_inline"
              ],
              "properties": {
                "columns": {
                  "type": "integer",
                  "minimum": 1
                },
                "gutter": {
                  "type": "string"
                },
                "margin_inline": {
                  "type": "string"
                }
              }
            },
            "breakpoints": {
              "type": "object",
              "minProperties": 3,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "opacity": {
          "type": "object",
          "minProperties": 2,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "type": [
              "string",
              "number"
            ]
          }
        }
      }
    },
    "components_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/componentSpec"
      }
    },
    "board": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_show",
        "spec_panel_sections",
        "notes"
      ],
      "properties": {
        "must_show": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "spec_panel_sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "template_image_path": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "paletteFamily": {
      "type": "object",
      "minProperties": 3,
      "propertyNames": {
        "pattern": "^(50|100|200|300|400|500|600|700|800|900)$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "stringMapMin1": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "stringMapMin3": {
      "type": "object",
      "minProperties": 3,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "stringMapMin4": {
      "type": "object",
      "minProperties": 4,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "stateName": {
      "type": "string",
      "enum": [
        "default",
        "hover",
        "focus-visible",
        "active",
        "selected",
        "checked",
        "unchecked",
        "open",
        "disabled",
        "error",
        "success",
        "loading",
        "readonly"
      ]
    },
    "componentSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "priority",
        "must_implement",
        "variants",
        "sizes",
        "states",
        "recipe"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "form",
            "navigation",
            "feedback",
            "data-display",
            "overlay",
            "layout",
            "selection"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "core",
            "recommended",
            "optional"
          ]
        },
        "must_implement": {
          "type": "boolean"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "sizes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stateName"
          },
          "minItems": 1
        },
        "anatomy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recipe": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "height",
            "padding_inline",
            "radius",
            "border_width",
            "shadow",
            "transition",
            "background",
            "text",
            "border"
          ],
          "properties": {
            "height": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "padding_inline": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "radius": {
              "type": "string"
            },
            "border_width": {
              "type": "string"
            },
            "shadow": {
              "type": "string"
            },
            "transition": {
              "type": "string"
            },
            "background": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "text": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "border": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]+$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
